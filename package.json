{
  "name": "mutation-lab",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "An incremental + roguelike where you grow a mutating cell.",
  "main": "electron/main.cjs",
  "scripts": {
    "sim": "node tools/sim.js",
    "dev": "python tools/devserver.py 8137",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mutationlab.game",
    "productName": "Mutation Lab",
    "files": [
      "index.html",
      "src/**/*",
      "styles/**/*",
      "vendor/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"]
    },
    "directories": {
      "output": "dist"
    }
  }
}
